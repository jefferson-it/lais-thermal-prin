    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "esbuild": "^0.20.1",
    "pkg": "^5.8.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^5.3.3"
  },
  "bin": "dist/index.js"
